<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FilmCrew-Matching</title>
    <link rel="stylesheet" href="/static/style.css">
    <link rel="stylesheet" href="/static/matching.css">
</head>


<body>
<%- include('partials/header') %>
    <header>
        <section>
            <img src="" alt="">
            <h1>Zoek talent. Of word gevonden.</h1>
            <p>Start een project. Sluit je aan.</p>
            <button>Vind projecten</button>
            <button>Vind talenten</button>
        </section>
    </header>

    <main>
        <section class="matching__containter">
            <h2>Vind jouw perfecte film match!</h2>
            <button>Filter op:</button>
            <button>Project type:</button>
            <button>Sorteren:</button>
            <button>Refresh</button>

            <article class="match__card">
                <h3>Naam</h3>
                <p>Beschrijving</p>
                <button>Bekijk details</button>
            </article>
        </section>

        <section class="reviews__container">
            <h2>Succesvolle matching verhalen</h2>
            <article class="review__card">
                <h3>Naam</h3>
                <p>Beschrijving</p>
            </article>
        </section>

        <section class="movie-article__container">
            <h2></h2>
            <article class="movie-article__card">
                <h3></h3>
                <p></p>
            </article>
        </section>
    </main>

    <footer>

    </footer>
</body>
</html>