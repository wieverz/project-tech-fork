<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/header') %>
<main>
    <h2 class="login__h2">Login</h2>
    <form class="login__form" action="/login" method="POST">
        <label for="username">Jouw Gebruikersnaam:</label>
        <input type="text" id="username" name="username" required>

        <label for="password">Wachtwoord:</label>
        <input type="password" id="password" name="password" required>

        <button class="login__login-btn" type="submit">Login</button>
    </form>
<p class="login__register-redirect">Heb je nog geen account? <a href="/register">maak hier een account</a></p>
    <script src="script.js"></script>
  </main>
</body>
</html>