<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Current Matches</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="/./static/partials/footer.css">
</head>


<body>
    <%- include('partials/header') %>
<main>
    <div class="current__new-match">
        <div class="current__active-notification">
            <h2 class="current__h2">Nieuwste Matches</h2>
            <div class="current__notification">!</div>
        </div>
        <div class="matches__filter-dropdown">
            <label class="matches__filter__label" for="sort">Sorteren op:</label>
            <select id="sort">
                <option value="most-recent">Meest recent</option>
                <option value="best-match">Beste match</option>
                <option value="a-z">A > Z</option>
                <option value="z-a">Z > A</option>
                <option value="oldest-first">Oudste eerst</option>
            </select>
        </div>
        <ul class="carousel__list">
            <% for (let i = 0; i < 5; i++) { %>
                <li class="carousel__list-Item">
                    <%- include('partials/matching') %>
                </li>
                <% } %>
        </ul> 
    </div>
    <div>
            <h2 class="current__h2">Huidige Projecten</h2>
            <div class="matches__filter-dropdown">
                <label class="matches__filter__label" for="sort">Sorteren op:</label>
                <select id="sort">
                    <option value="most-recent">Meest recent</option>
                    <option value="best-match">Beste match</option>
                    <option value="a-z">A > Z</option>
                    <option value="z-a">Z > A</option>
                    <option value="oldest-first">Oudste eerst</option>
                </select>
            </div>
            <ul class="carousel__list current__matches">
                <% for (let i = 0; i < 5; i++) { %>
                  <li class="carousel__list-Item <%= i === 0 ? 'first-item-active' : '' %>">
                    <%- include('partials/matching') %>
                  </li>
                <% } %>
              </ul>
    </div>
</main>
<%- include('partials/footer') %>
</body>
</html>