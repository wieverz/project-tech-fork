<nav class="tag-container crew-profile-edit" aria-label="Project categories">
    <ul class="tag-list" id="tagList"> 
        <% projectData.tags && projectData.tags.forEach((tag) => { %>
            <li class="tag">
                <%= tag %>
                <button type="button" class="remove-tag edit-only" onclick="this.parentElement.remove()">×</button>
            </li>
        <% }) %>
    </ul>

    <div class="edit-only">
        <select id="tag-select">
            <option value="" disabled selected>Kies een filter...</option>
            <option value="Sci-Fi">Sci-Fi</option>
            <option value="Action">Action</option>
            <option value="Horror">Horror</option>
            <option value="Comedy">Comedy</option>
        </select>
        <button type="button" class="add-tag-btn" onclick="addTagFromSelect()">Voeg toe</button>
    </div>

    <input type="hidden" name="tags" id="inputTags">
</nav>