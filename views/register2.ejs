<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registreer</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/header') %>
<main>
    <h2 class="register__h2">Nieuw account aanmaken</h2>
    <form class="register__form" action="/register" method="POST" novalidate>
        <label for="function">Wat is jouw functie?</label>
        <input type="text" id="username" name="username" placeholder="Bijvoorbeeld: Regisseur" required>
        <span class="register__error-message" id="username-error">Vul a.u.b. je functie in</span>

        <label for="description">Vertel een beschrijving over jezelf</label>
        <input type="text" id="description" name="description" placeholder="Bijvoorbeeld: Videographer die aan grote hollyhoow films heeft meegewerkt">

        <label for="experience">Wat is jouw werkervaring: <span id="val">5</span> jaar</label>
        <input type="range" id="experience" name="experience" min="0" max="40" value="5">

        <button class="register__volgende-btn" type="submit"><a href="/register">Vorige stap</a></button>
        <button class="register__registreer-btn" type="submit"><a href="/login">Registreer</a></button>
    </form>
    <p class="register__login-redirect" >Heb je al een account? <a href="/login">Log hier in</a></p>
</main>
<script src="/static/js/login-register.js"></script>
</body>
</html>